# Copy to .env and fill in values
# For Docker Compose dev: DATABASE_HOST is overridden by compose to "postgres"

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=inverumdb
DATABASE_USER=inverum
DATABASE_PASSWORD=devpassword
DATABASE_TYPE=postgresql

# Optional: reporting replica (HAProxy port 5001 in prod)
# DATABASE_REPORTING_URL=postgresql://inverum:devpassword@localhost:5001/inverumdb

APP_NAME=Inverum
APP_VERSION=0.1.0
DEBUG=True
SECRET_KEY=change-me-in-production

VALKEY_URL=valkey://:devpassword@localhost:6379/0
VALKEY_PASSWORD=devpassword

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=inverum
MINIO_SECRET_KEY=devpassword
MINIO_BUCKET=inverum-dev
MINIO_SECURE=false

ENVIRONMENT=dev
SEED_COMPLEXITY=simple

INTERNAL_API_KEY=change-me-in-production

# OpenTelemetry (disabled by default)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=inverum

# Vendor API enrichers (optional)
DELL_API_KEY=
DELL_API_SECRET=
